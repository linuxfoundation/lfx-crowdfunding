# LFX Crowdfunding Initiatives API — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit a .env file containing secrets.

# ─── HTTP Server ─────────────────────────────────────────────────────────────
PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=30s

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Full connection string including search_path for the crowdfunding schema.
DATABASE_URL=postgres://user:password@localhost:5432/lfxdb?search_path=crowdfunding&sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_CONN_MAX_LIFETIME=5m

# ─── Auth0 / JWT ─────────────────────────────────────────────────────────────
JWKS_URL=https://<your-auth0-domain>/.well-known/jwks.json
# Must exactly match the API identifier registered in Auth0 (no trailing slash).
JWT_AUDIENCE=https://<your-api-audience>
JWT_ISSUER=https://<your-auth0-domain>/
# Optional: dedicated audience for M2M-only tokens (e.g. LfxSelfServe
# client_credentials calls). When set, a second JWT authenticator is created
# that accepts tokens with this audience on /me/* routes, in addition to the
# main JWT_AUDIENCE. Leave empty to disable.
# JWT_M2M_AUDIENCE=https://<your-m2m-audience>
# Optional: whitespace-separated list of allowed client IDs (azp/client_id/sub)
# enforced on all token types. Leave empty to disable this guard.
# When non-empty, also gates the X-Username header impersonation
# feature: only tokens issued to a listed client may supply the acting user's
# identity via the X-Username header. A startup warning is logged
# when active. Ensure the ingress strips the header before forwarding requests.
# Example: lfx-self-serve-client lfx-self-serve-local
AUTHORIZED_CLIENTS=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TIMEOUT=30s
# Set to true in pre-production environments receiving real Stripe deliveries
# before DB persistence is implemented. Causes recognised-but-unimplemented
# event types to respond 200 (ack) instead of 501 (retry). Never set in prod.
STRIPE_WEBHOOK_ACK_UNIMPLEMENTED=false

# ─── Ledger service ──────────────────────────────────────────────────────────
LEDGER_BASE_URL=https://ledger-api.lfx.dev
LEDGER_API_KEY=
LEDGER_TIMEOUT=10s

# ─── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=lfx-v2-initiatives-service
OTEL_SERVICE_VERSION=dev
# Leave empty to disable trace export (no-op tracer is used).
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── S3 logo uploads ─────────────────────────────────────────────────────────
# Name of the S3 bucket used for presigned logo uploads (e.g. lfx-<stage>-uploads).
S3_UPLOAD_BUCKET=lfx-dev-uploads
# AWS region for the bucket. Leave empty to use AWS_REGION / AWS_DEFAULT_REGION.
S3_REGION=us-east-1
# How long a presigned PUT URL remains valid. Defaults to 3m.
S3_PRESIGN_EXPIRY=3m

# ─── Local dev only ──────────────────────────────────────────────────────────
# Must be true to allow DISABLED_MOCK_LOCAL_PRINCIPAL. Keep false everywhere
# except isolated local development.
ALLOW_MOCK_LOCAL_PRINCIPAL_BYPASS=false
# Leave empty by default. Any non-empty value bypasses JWT validation and is
# used as the mock principal UserID for local development only.
# NEVER enable in staging or production.
DISABLED_MOCK_LOCAL_PRINCIPAL=

# ─── Approvals ───────────────────────────────────────────────────────────────
# Comma-separated list of LF SSO usernames permitted to approve or decline
# initiatives via POST /v1/initiatives/{id}/process-approval/{action}.
# Example: ALLOWED_APPROVERS=alice,bob,carol
ALLOWED_APPROVERS=

# ─── Mandrill transactional email ─────────────────────────────────────────────
# Leave MANDRILL_API_KEY empty to disable email notifications (non-critical).
MANDRILL_API_KEY=
MANDRILL_FROM_EMAIL=noreply@lfx.linuxfoundation.org
MANDRILL_FROM_NAME=LFX Crowdfunding
MANDRILL_FRONTEND_BASE=https://crowdfunding.lfx.linuxfoundation.org
MANDRILL_NOTIFICATION_EMAIL=crowdfunding-reviewers@linuxfoundation.org
