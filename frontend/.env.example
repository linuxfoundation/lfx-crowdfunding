# LFX Crowdfunding Frontend — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit a .env file containing secrets.

# ─── App ─────────────────────────────────────────────────────────────────────
NUXT_APP_ENV=development
# Public URL of this app. Defaults to http://localhost:3000.
# Required in production. Used for Auth0 redirect URIs and Stripe return URL.
NUXT_APP_URL=http://localhost:3000

# ─── Auth0 ───────────────────────────────────────────────────────────────────
NUXT_PUBLIC_AUTH0_DOMAIN=https://linuxfoundation-dev.auth0.com
NUXT_PUBLIC_AUTH0_CLIENT_ID=
NUXT_AUTH0_CLIENT_SECRET=
# Cookie domain for cross-subdomain auth cookies.
# Leave unset for local dev — localhost is used automatically.
# Required in staging/production, e.g. platform.linuxfoundation.org
# NUXT_AUTH0_COOKIE_DOMAIN=

# ─── Session ─────────────────────────────────────────────────────────────────
# Secret used to sign the auth_oidc_token session cookie (HS256).
# Generate with: openssl rand -hex 32
NUXT_JWT_SECRET=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Publishable key is public (safe to expose to browser via NUXT_PUBLIC_ prefix).
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── GitHub OAuth ────────────────────────────────────────────────────────────
# Used by the fundraise flow to connect a GitHub repo to an initiative.
NUXT_PUBLIC_GITHUB_OAUTH_CLIENT_ID=
NUXT_GITHUB_OAUTH_CLIENT_SECRET=
