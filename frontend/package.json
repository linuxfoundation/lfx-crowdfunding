    "@vueuse/core": "^14.1.0",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "nuxt": "^4.2.2",
    "ofetch": "^1.5.1",
    "openid-client": "^6.8.1",
    "pinia": "^3.0.4",
    "primevue": "^4.5.4",
