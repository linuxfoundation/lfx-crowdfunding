{
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "variants",
          "responsive",
          "screen",
          "config",
          "use",
          "forward",
          "mixin",
          "include",
          "each",
          "function",
          "return",
          "if",
          "else",
          "warn",
          "error"
        ]
      }
    ]
  }
}
